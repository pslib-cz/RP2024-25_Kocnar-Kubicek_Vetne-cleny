{
  "expo": {
    "name": "Větná dráha",
    "slug": "vetnecleny",
    "version": "1.0.5",
    "orientation": "portrait",
    "icon": "./assets/images/icons/ios-dark.png",
    "scheme": "vetnecleny",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "cz.pslib.vetnecleny",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "icon": {
        "dark": "./assets/images/icons/ios-dark.png",
        "light": "./assets/images/icons/ios-light.png",
        "tinted": "./assets/images/icons/ios-tinted.png"
      },
      "buildNumber": "35"
    },
    "android": {
      "versionCode": 9,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icons/adaptive-icon.png",
        "backgroundColor": "#101223"
      },
      "package": "cz.pslib.vetnecleny"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/icons/ios-dark.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#101223",
          "image": "./assets/images/icons/splash-icon-light.png",
          "dark": {
            "image": "./assets/images/icons/splash-icon-dark.png",
            "backgroundColor": "#101223"
          },
          "imageWidth": 200
        }
      ],
      "expo-asset",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "_commentedProjectId": "2f64e818-76b7-4947-9100-4287fa3f8501",
        "projectId": "2f64e818-76b7-4947-9100-4287fa3f8501"
      }
    }
  }
}
